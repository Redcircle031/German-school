// Environment variables for Sanity.io
# Get these from https://sanity.io/manage

# Sanity Project ID (found in project settings)
NEXT_PUBLIC_SANITY_PROJECT_ID="your-project-id"

# Sanity Dataset (usually 'production')
NEXT_PUBLIC_SANITY_DATASET="production"

# Sanity API Token (create in Manage > API > Tokens)
# Use "Editor" role for CMS access
SANITY_API_TOKEN="your-api-token"

# Sanity Studio URL (for CORS)
NEXT_PUBLIC_SANITY_STUDIO_URL="https://your-project-id.sanity.studio"
