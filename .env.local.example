# ==========================================
# WBS School Website - Environment Variables
# ==========================================

# --- Admin Authentication ---
# REQUIRED: All three must be set or the app will not start.
# Generate bcrypt password hash: node -e "require('bcryptjs').hash('your-password', 12).then(h => console.log(h))"
# Generate session secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_EMAIL=admin@wbs.pl
ADMIN_PASSWORD_HASH=<generate-bcrypt-hash-above>
SESSION_SECRET=<generate-random-hex-above>

# --- SMTP Email (Contact Form) ---
# Configure these to enable email sending from contact form
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
CONTACT_FORM_EMAIL=sekretariat@wbs.pl

# --- Sanity CMS (Optional) ---
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=your-api-token
