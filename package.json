    "clsx": "^2.1.0",
    "date-fns": "^3.3.0",
    "framer-motion": "^11.0.0",
    "gray-matter": "^4.0.3",
    "html-to-text": "^9.0.5",
    "lucide-react": "^0.344.0",
    "next": "^16.1.6",
    "next-intl": "^3.9.0",
    "pdf-parse": "^2.4.5",
    "plausible-tracker": "^0.3.8",
